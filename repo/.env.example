# ------------------------------------------------------------------
# SilverScreen Environment Configuration
# Copy this file to .env and replace every CHANGE_ME value.
# docker-compose.yml reads from .env — no secrets in compose file.
# ------------------------------------------------------------------

# --- Database ---
POSTGRES_DB=silverscreen
POSTGRES_USER=silverscreen
POSTGRES_PASSWORD=CHANGE_ME_use_a_strong_random_password

# --- Auth / JWT ---
JWT_SECRET=CHANGE_ME_use_openssl_rand_hex_64_to_generate

# --- Encryption (must be exactly 32 bytes) ---
ENCRYPTION_KEY=CHANGE_ME_use_openssl_rand_hex_32

# --- Backup ---
BACKUP_ENCRYPTION_KEY=CHANGE_ME_use_a_different_random_key

# --- TLS (set to "true" for production) ---
ENABLE_TLS=false

# --- Dev mode: warn on placeholder secrets instead of panicking ---
# Set to "true" for local development so the app starts with default secrets.
# MUST be "false" or removed for production deployments.
SILVERSCREEN_DEV_MODE=true
